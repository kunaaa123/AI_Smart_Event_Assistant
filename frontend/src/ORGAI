        if len(images) > 0:
            return jsonify({
                "success": True,
                "images": images,  # ส่งกลับเป็น array ของ base64
                "count": len(images),
                "model_used": result.get("model", "unknown"),
                "prompt": prompt,
                "enhanced_prompt": enhanced_prompt
            })
