    try:
        if not request.is_json:
            return jsonify({"error": "Content-Type ต้องเป็น application/json"}), 400
        
        data = request.json
        prompt = data.get("prompt", "").strip()
        count = data.get("count", 3)  # จำนวนภาพที่ต้องการ
        
        if not prompt:
            return jsonify({"error": "กรุณาใส่คำอธิบายบัตรเชิญ"}), 400
        
        if len(prompt) > 500:
            return jsonify({"error": "คำอธิบายยาวเกินไป (สูงสุด 500 ตัวอักษร)"}), 400
        
        logger.info(f"Generating invitation album with prompt: {prompt}, count: {count}")
        
        # สร้างภาพหลายรูป
        images = []
        enhanced_prompt = enhance_prompt_for_invitations(prompt)
        
        for i in range(count):
            # เพิ่มความหลากหลายในแต่ละรูป
            variation_prompt = f"{enhanced_prompt}, variation {i+1}, different composition"
            result = generate_image_with_retry(variation_prompt)
            
