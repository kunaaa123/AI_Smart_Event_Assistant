def get_working_models():
    """ตรวจสอบ models ที่ทำงานได้"""
    headers = {
        "Authorization": f"Bearer {HUGGING_FACE_API_TOKEN}",
    }
    
    working_models = []
    
    test_models = [
        "black-forest-labs/FLUX.1-schnell",
        "stabilityai/stable-diffusion-3-medium-diffusers", 
        "Artples/LAI-ImageGeneration-vSDXL-2",
        "XLabs-AI/flux-RealismLora",
        "stabilityai/sdxl-turbo",
        "runwayml/stable-diffusion-v1-5",
        "stabilityai/stable-diffusion-2-1",
        "CompVis/stable-diffusion-v1-4"
    ]
    
    for model in test_models:
        try:
            response = requests.get(
                f"https://huggingface.co/api/models/{model}",
                headers=headers,
                timeout=5
            )
            if response.status_code == 200:
                working_models.append(model)
                logger.info(f"✅ Model working: {model}")
            else:
                logger.warning(f"❌ Model not available: {model} (Status: {response.status_code})")
        except Exception as e:
            logger.error(f"❌ Error checking model {model}: {str(e)}")
    
    return working_models

def generate_image_with_retry(prompt, max_retries=3):
    """สร้างรูปภาพพร้อม retry logic และ translation"""
    
    working_models = get_working_models()
    
    if not working_models:
        logger.error("ไม่พบ models ที่ทำงานได้")
        return {
            "success": False,
            "error": "ไม่พบ AI models ที่ใช้งานได้ กรุณาตรวจสอบ Token หรือลองใหม่อีกครั้ง"
        }
    
    headers = {
        "Authorization": f"Bearer {HUGGING_FACE_API_TOKEN}",
        "Content-Type": "application/json"
    }
    
    for model in working_models:
        logger.info(f"🔄 Trying model: {model}")
        
        for attempt in range(max_retries):
            try:
                # ใช้ฟังก์ชันใหม่สำหรับปรับปรุง prompt
                enhanced_prompt = enhance_prompt_for_events(prompt)
                logger.info(f"Enhanced prompt: {enhanced_prompt}")
                
                response = requests.post(
                    f"https://api-inference.huggingface.co/models/{model}",
                    headers=headers,
                    json={"inputs": enhanced_prompt},
                    timeout=60
                )
                
                logger.info(f"Attempt {attempt + 1}, Status: {response.status_code}")
                
                if response.status_code == 200:
                    content_type = response.headers.get('content-type', '')
                    content_length = len(response.content)
                    
                    if 'image' in content_type or content_length > 1000:
                        logger.info(f"✅ Success with model: {model}")
                        return {
                            "success": True,
                            "content": response.content,
                            "model": model,
                            "prompt_used": enhanced_prompt,
                            "original_prompt": prompt
                        }
                    else:
                        logger.warning(f"Invalid response from {model}")
                        continue
                        
                elif response.status_code == 503:
                    logger.info(f"⏳ Model loading: {model}, waiting...")
                    time.sleep(15)
                    continue
                    
                elif response.status_code == 429:
                    logger.warning(f"⚠️ Rate limited on {model}, waiting...")
                    time.sleep(10)
                    continue
                    
                else:
                    logger.error(f"❌ Error {response.status_code} from {model}")
                    break
                    
            except requests.exceptions.Timeout:
                logger.warning(f"⏱️ Timeout on {model} attempt {attempt + 1}")
                if attempt < max_retries - 1:
                    time.sleep(5)
                    continue
                    
            except Exception as e:
                logger.error(f"❌ Exception on {model}: {str(e)}")
                if attempt < max_retries - 1:
                    time.sleep(3)
                    continue
    
    return {
        "success": False,
        "error": "ไม่สามารถสร้างรูปภาพได้จาก AI models ทั้งหมด กรุณาลองใหม่อีกครั้ง"
    }

